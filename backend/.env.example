# ============================================================================
# EXAMPLE ENVIRONMENT FILE - Copy to .env and fill in your values
# NEVER commit the actual .env file with real API keys to GitHub!
# ============================================================================

# ============================================================================
# SECURITY - API KEYS (Keep these secret!)
# ============================================================================

# Groq API Key - Get from https://console.groq.com
# Required for the /ask endpoint to work
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# CORS Configuration
# ============================================================================

# Allowed origins for frontend requests (comma-separated)
# For production, use your actual domain (e.g., https://yourdomain.com)
CORS_ORIGINS=https://rag-chatbot.netlify.app,http://localhost:5173,http://localhost:8000

# ============================================================================
# Server Configuration
# ============================================================================

# Port to run the backend server on
PORT=8000

# Environment mode (development or production)
# Set to 'production' for deployment to hide API docs
ENVIRONMENT=development

# ============================================================================
# LLM Configuration (optional - uses defaults if not set)
# ============================================================================

# Embedding model for semantic search
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model to use
# LLM_MODEL=llama-3.1-8b-instant

# Temperature for LLM (0.0 = deterministic, 1.0 = creative)
# LLM_TEMPERATURE=0.1

# ============================================================================
# PDF Processing Configuration (optional - uses defaults if not set)
# ============================================================================

# Chunk size for text splitting (in characters)
# CHUNK_SIZE=500

# Overlap between chunks (in characters)
# CHUNK_OVERLAP=100

# Number of top results to retrieve
# TOP_K_FINAL=5
